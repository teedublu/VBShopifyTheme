{%- render 'section-spacing-collapsing' -%}

{% assign object_type = section.settings.object_type %}
{%- assign page_size = section.settings.page_size | plus: 0 -%}
{%- if page_size < 1 -%}
  {%- assign page_size = 25 -%}
{%- endif -%}

<style>
  #shopify-section-{{ section.id }} .object-directory {
    display: grid;
    gap: 1.25rem;
  }

  #shopify-section-{{ section.id }} .object-directory__intro {
    max-width: 72ch;
    margin-inline: auto;
    text-align: center;
  }

  #shopify-section-{{ section.id }} .object-directory__eyebrow {
    margin: 0 0 0.35rem;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(var(--text-color), 0.68);
  }

  #shopify-section-{{ section.id }} .object-directory__heading {
    margin: 0;
    font-size: clamp(1.8rem, 3vw, 2.5rem);
    line-height: 1.08;
  }

  #shopify-section-{{ section.id }} .object-directory__description {
    margin: 0.6rem 0 0;
    font-size: 0.98rem;
    line-height: 1.6;
    color: rgba(var(--text-color), 0.78);
  }

  #shopify-section-{{ section.id }} .object-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.65rem;
  }

  #shopify-section-{{ section.id }} .object-item {
    display: grid;
    grid-template-columns: 56px minmax(0, 1fr);
    gap: 0.75rem;
    align-items: center;
    padding: 0.7rem 0.85rem;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.78);
  }

  #shopify-section-{{ section.id }} .object-item[id] {
    scroll-margin-top: 8rem;
  }

  #shopify-section-{{ section.id }} .object-image {
    width: 56px;
    height: 56px;
    overflow: hidden;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #shopify-section-{{ section.id }} .object-image img,
  #shopify-section-{{ section.id }} .object-image svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  #shopify-section-{{ section.id }} .object-text {
    min-width: 0;
  }

  #shopify-section-{{ section.id }} .object-title {
    margin: 0;
    font-size: 1rem;
    line-height: 1.25;
  }

  #shopify-section-{{ section.id }} .object-meta,
  #shopify-section-{{ section.id }} .object-description {
    margin-top: 0.2rem;
  }

  #shopify-section-{{ section.id }} .object-meta {
    font-size: 0.88rem;
    line-height: 1.4;
  }

  #shopify-section-{{ section.id }} .object-description {
    font-size: 0.9rem;
    line-height: 1.45;
    color: rgba(var(--text-color), 0.78);
  }

  #shopify-section-{{ section.id }} .object-meta a {
    font-weight: 700;
  }

  #shopify-section-{{ section.id }} .object-pagination {
    margin-top: 1.5rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
    align-items: center;
  }

  #shopify-section-{{ section.id }} .object-pagination__link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2rem;
    min-height: 2rem;
    padding: 0.2rem 0.45rem;
    border-radius: 999px;
    border: 1px solid rgba(0, 0, 0, 0.08);
    background: rgba(255, 255, 255, 0.85);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 700;
  }

  #shopify-section-{{ section.id }} .object-pagination__link.is-active {
    background: rgb(var(--text-color));
    color: rgb(var(--background));
    border-color: rgb(var(--text-color));
  }
</style>

<div {% render 'section-properties' %}>
  <div class="container">
    <div class="page">
      <div class="metaobjects index-list collection object-directory">
        {%- if section.settings.eyebrow != blank or section.settings.heading != blank or section.settings.description != blank -%}
          <div class="object-directory__intro">
            {%- if section.settings.eyebrow != blank -%}
              <p class="object-directory__eyebrow">{{ section.settings.eyebrow | escape }}</p>
            {%- endif -%}
            {%- if section.settings.heading != blank -%}
              <h1 class="object-directory__heading">{{ section.settings.heading | escape }}</h1>
            {%- endif -%}
            {%- if section.settings.description != blank -%}
              <div class="object-directory__description rte">{{ section.settings.description }}</div>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- if object_type == 'audiobooks' -%}
          {% paginate collections['audiobooks'].products by page_size %}
            <ul class="object-list">
              {%- for product in collections['audiobooks'].products -%}
                {%- assign audiobook = product.metafields.book.audiobook.value -%}
                {%- if audiobook == blank -%}
                  {%- continue -%}
                {%- endif -%}

                {%- assign review = product.metafields.book.review.value -%}
                {%- assign authors = product.metafields.book.authors.value -%}
                {%- assign narrators = product.metafields.book.narrators.value -%}
                {%- assign blurb = audiobook.concise_blurb | default: audiobook.short_blurb | default: audiobook.page_description | metafield_tag | strip_html | strip -%}

                <li class="object-item">
                  <a class="object-image" href="{{ audiobook.system.url }}">
                    {%- if product.featured_image != blank -%}
                      {{
                        product.featured_image
                        | image_url: width: 240
                        | image_tag:
                          loading: 'lazy',
                          widths: '72, 96, 144, 240',
                          sizes: '72px',
                          alt: product.title
                      }}
                    {%- else -%}
                      {{ 'product-1' | placeholder_svg_tag: 'placeholder' }}
                    {%- endif -%}
                  </a>

                  <div class="object-text">
                    <h2 class="object-title h5">
                      <a href="{{ audiobook.system.url }}">{{ audiobook.title.value | default: product.title }}</a>
                      {%- if review != blank -%}
                        <span class="review">({{ 'read the review' | link_to: review.system.url, class: 'link review' }})</span>
                      {%- endif -%}
                    </h2>

                    {%- if authors != blank -%}
                      <div class="object-meta">
                        Written by:
                        {%- for author in authors -%}
                          {{ author.name | link_to: author.system.url, class: 'author link' }}{% unless forloop.last %}, {% endunless %}
                        {%- endfor -%}
                      </div>
                    {%- endif -%}

                    {%- if narrators != blank -%}
                      <div class="object-meta">
                        Narrated by:
                        {%- for narrator in narrators -%}
                          {{ narrator.name | link_to: narrator.system.url, class: 'narrator link' }}{% unless forloop.last %}, {% endunless %}
                        {%- endfor -%}
                      </div>
                    {%- endif -%}

                    {%- if blurb != blank -%}
                      <div class="object-description">{{ blurb | truncate: 190 }}</div>
                    {%- endif -%}
                  </div>
                </li>
              {%- endfor -%}
            </ul>

            {%- capture item_list_elements -%}
              {%- for product in collections['audiobooks'].products -%}
                {%- assign audiobook = product.metafields.book.audiobook.value -%}
                {%- if audiobook == blank -%}
                  {%- continue -%}
                {%- endif -%}
                {
                  "@type": "ListItem",
                  "position": {{ paginate.current_offset | plus: forloop.index }},
                  "url": {{ audiobook.system.url | prepend: shop.url | json }},
                  "name": {{ audiobook.title.value | default: product.title | json }}
                }[[[item]]]
              {%- endfor -%}
            {%- endcapture -%}
            {%- assign item_list_entries = item_list_elements | split: '[[[item]]]' -%}
            <script type="application/ld+json">
              {
                "@context": "https://schema.org",
                "@type": "ItemList",
                "name": {{ section.settings.heading | default: page.title | json }},
                "numberOfItems": {{ paginate.items }},
                "itemListOrder": "https://schema.org/ItemListOrderAscending",
                "itemListElement": [
                  {%- for entry in item_list_entries -%}
                    {%- if entry == blank -%}
                      {%- continue -%}
                    {%- endif -%}
                    {{ entry }}{% unless forloop.last %},{% endunless %}
                  {%- endfor -%}
                ]
              }
            </script>

            {%- render 'pagination', paginate: paginate, class: 'object-pagination', mode: 'full', show_first_last: true, show_head_links: true, canonical_url: canonical_url -%}
          {% endpaginate %}
        {%- else -%}
          {%- liquid
            assign metaobject_type = blank
            assign paginated_values = blank
            case object_type
              when 'authors'
                assign metaobject_type = 'author'
                assign paginated_values = metaobjects.author.values
              when 'narrators'
                assign metaobject_type = 'narrator'
                assign paginated_values = metaobjects.narrator.values
              when 'characters'
                assign metaobject_type = 'character'
                assign paginated_values = metaobjects.character.values
              when 'publishers'
                assign metaobject_type = 'publisher'
                assign paginated_values = metaobjects.publisher.values
              when 'overviews'
                assign metaobject_type = 'overview'
                assign paginated_values = metaobjects.overview.values
              when 'audiogrammes'
                assign metaobject_type = 'audiogramme'
                assign paginated_values = metaobjects.audiogramme.values
              when 'series'
                assign metaobject_type = 'series'
                assign paginated_values = metaobjects.series.values
            endcase
          -%}

          {%- if paginated_values != blank -%}
            {% paginate paginated_values by page_size %}
              <ul class="object-list">
                {%- for object in paginated_values -%}
                  {%- assign object_name = object.name | default: object.title.value | strip -%}
                  {%- if object_name == blank -%}
                    {%- continue -%}
                  {%- endif -%}

                  {%- assign image = blank -%}
                  {%- assign description = object.description | default: object.bio -%}
                  {%- if object.logo != blank -%}
                    {%- assign image = object.logo.value | default: object.logo -%}
                  {%- elsif object.image != blank -%}
                    {%- assign image = object.image.value | default: object.image -%}
                  {%- elsif object.photos != blank -%}
                    {%- assign image = object.photos.value | first -%}
                  {%- elsif object.product != blank and object.product.value != blank -%}
                    {%- assign image = object.product.value.featured_image -%}
                  {%- endif -%}

                  {%- assign object_link_class = object_type | append: ' link' -%}

                  <li class="object-item">
                    <a class="object-image" href="{{ object.system.url }}">
                      {% render 'person-avatar', metaobject: object, radius: section.settings.radius, max_width: 56, image_to_use: image, avatar_bg_color: section.settings.avatar_bg_color, avatar_display: section.settings.avatar_display, initials_color: section.settings.initials_color, initials_font_size: section.settings.initials_font_size %}
                    </a>
                    <div class="object-text">
                      <h2 class="object-title h5">
                        {{ object_name | link_to: object.system.url, class: object_link_class }}
                        {%- if metaobject_type == 'publisher' and object.collection.value != blank -%}
                          <span class="review">({{ 'view collection' | link_to: object.collection.value.url, class: 'link' }})</span>
                        {%- endif -%}
                      </h2>
                      {%- if description != blank -%}
                        <div class="object-description">{{ description | metafield_tag | strip_html | truncate: 170 }}</div>
                      {%- endif -%}
                    </div>
                  </li>
                {%- endfor -%}
              </ul>

              {%- capture item_list_elements -%}
                {%- for object in paginated_values -%}
                  {%- assign object_name = object.name | default: object.title.value | strip -%}
                  {%- if object_name == blank -%}
                    {%- continue -%}
                  {%- endif -%}
                  {
                    "@type": "ListItem",
                    "position": {{ paginate.current_offset | plus: forloop.index }},
                    "url": {{ object.system.url | prepend: shop.url | json }},
                    "name": {{ object_name | json }}
                  }[[[item]]]
                {%- endfor -%}
              {%- endcapture -%}
              {%- assign item_list_entries = item_list_elements | split: '[[[item]]]' -%}
              <script type="application/ld+json">
                {
                  "@context": "https://schema.org",
                  "@type": "ItemList",
                  "name": {{ section.settings.heading | default: page.title | json }},
                  "numberOfItems": {{ paginate.items }},
                  "itemListOrder": "https://schema.org/ItemListOrderAscending",
                  "itemListElement": [
                    {%- for entry in item_list_entries -%}
                      {%- if entry == blank -%}
                        {%- continue -%}
                      {%- endif -%}
                      {{ entry }}{% unless forloop.last %},{% endunless %}
                    {%- endfor -%}
                  ]
                }
              </script>

              {%- render 'pagination', paginate: paginate, class: 'object-pagination', mode: 'full', show_first_last: true, show_head_links: true, canonical_url: canonical_url -%}
            {% endpaginate %}
          {%- endif -%}
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Metaobjects list",
  "class": "shopify-section--logo-list",
  "tag": "section",
  "disabled_on": {
    "templates": ["password"],
    "groups": ["header", "custom.overlay"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Metaobjects",
      "info": "Paginated list of metaobjects."
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "range",
      "id": "page_size",
      "label": "Page size",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 25
    },
    {
      "type": "select",
      "id": "object_type",
      "label": "Object type",
      "options": [
        {
          "value": "audiobooks",
          "label": "Audiobooks"
        },
        {
          "value": "authors",
          "label": "Authors"
        },
        {
          "value": "narrators",
          "label": "Narrators"
        },
        {
          "value": "characters",
          "label": "Characters"
        },
        {
          "value": "publishers",
          "label": "Publishers"
        },
        {
          "value": "overviews",
          "label": "Overviews"
        },
        {
          "value": "audiogrammes",
          "label": "Audiogrammes"
        },
        {
          "value": "series",
          "label": "Series"
        }
      ],
      "info": "Choose a metaobject to paginate over",
      "default": "authors"
    },
    {
      "type": "radio",
      "id": "avatar_display",
      "label": "Avatar display style",
      "default": "image",
      "options": [
        { "value": "image", "label": "Image" },
        { "value": "initials", "label": "Initials" },
        { "value": "placeholder", "label": "Placeholder" }
      ]
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 100,
      "max": 500,
      "step": 10,
      "unit": "px",
      "label": "Maximum width",
      "default": 200
    },
    {
      "type": "range",
      "id": "radius",
      "min": 0,
      "max": 50,
      "step": 10,
      "unit": "%",
      "label": "Image radius",
      "default": 30
    },
    {
      "type": "range",
      "id": "initials_font_size",
      "label": "Initials font size",
      "min": 5,
      "max": 200,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "color",
      "id": "initials_color",
      "label": "Initials color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "avatar_bg_color",
      "label": "Initials background",
      "default": "#ffffff"
    }
  ],
  "blocks": [

  ],
  "presets": [
    {
      "name": "Metaobjects list",
      "blocks": [
        
      ]
    }
  ]
}
{% endschema %}
