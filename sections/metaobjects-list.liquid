{%- render 'section-spacing-collapsing' -%}

{% assign object_type = section.settings.object_type %}

<style>
  #shopify-section-{{ section.id }} .object-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 1rem;
  }

  #shopify-section-{{ section.id }} .object-item {
    display: grid;
    grid-template-columns: 72px minmax(0, 1fr);
    gap: 1rem;
    align-items: start;
    padding: 1rem;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.92);
  }

  #shopify-section-{{ section.id }} .object-item[id] {
    scroll-margin-top: 8rem;
  }

  #shopify-section-{{ section.id }} .object-image {
    width: 72px;
    height: 72px;
    overflow: hidden;
    border-radius: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #shopify-section-{{ section.id }} .object-image img,
  #shopify-section-{{ section.id }} .object-image svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  #shopify-section-{{ section.id }} .object-text {
    min-width: 0;
  }

  #shopify-section-{{ section.id }} .object-title {
    margin: 0;
    font-size: 1.05rem;
    line-height: 1.3;
  }

  #shopify-section-{{ section.id }} .object-meta,
  #shopify-section-{{ section.id }} .object-description {
    margin-top: 0.35rem;
  }

  #shopify-section-{{ section.id }} .object-meta {
    font-size: 0.92rem;
    line-height: 1.5;
  }

  #shopify-section-{{ section.id }} .object-description {
    font-size: 0.95rem;
    line-height: 1.55;
    color: rgba(var(--text-color), 0.78);
  }

  #shopify-section-{{ section.id }} .object-meta a {
    font-weight: 700;
  }

  #shopify-section-{{ section.id }} .object-pagination {
    margin-top: 1.5rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
    align-items: center;
  }

  #shopify-section-{{ section.id }} .object-pagination__link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2rem;
    min-height: 2rem;
    padding: 0.2rem 0.45rem;
    border-radius: 999px;
    border: 1px solid rgba(0, 0, 0, 0.08);
    background: rgba(255, 255, 255, 0.85);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 700;
  }

  #shopify-section-{{ section.id }} .object-pagination__link.is-active {
    background: rgb(var(--text-color));
    color: rgb(var(--background));
    border-color: rgb(var(--text-color));
  }
</style>

<div {% render 'section-properties' %}>
  <div class="container">
    <div class="page">
      <div class="metaobjects index-list collection">
        {%- if object_type == 'audiobooks' -%}
          {% paginate collections['audiobooks'].products by section.settings.page_size %}
            <ul class="object-list">
              {%- for product in collections['audiobooks'].products -%}
                {%- assign audiobook = product.metafields.book.audiobook.value -%}
                {%- if audiobook == blank -%}
                  {%- continue -%}
                {%- endif -%}

                {%- assign review = product.metafields.book.review.value -%}
                {%- assign authors = product.metafields.book.authors.value -%}
                {%- assign narrators = product.metafields.book.narrators.value -%}
                {%- assign blurb = audiobook.concise_blurb | default: audiobook.short_blurb | default: audiobook.page_description | metafield_tag | strip_html | strip -%}

                <li class="object-item">
                  <a class="object-image" href="{{ audiobook.system.url }}">
                    {%- if product.featured_image != blank -%}
                      {{
                        product.featured_image
                        | image_url: width: 240
                        | image_tag:
                          loading: 'lazy',
                          widths: '72, 96, 144, 240',
                          sizes: '72px',
                          alt: product.title
                      }}
                    {%- else -%}
                      {{ 'product-1' | placeholder_svg_tag: 'placeholder' }}
                    {%- endif -%}
                  </a>

                  <div class="object-text">
                    <p class="object-title">
                      <a href="{{ audiobook.system.url }}">{{ audiobook.title.value | default: product.title }}</a>
                      {%- if review != blank -%}
                        <span class="review">({{ 'read the review' | link_to: review.system.url, class: 'link review' }})</span>
                      {%- endif -%}
                    </p>

                    {%- if authors != blank -%}
                      <div class="object-meta">
                        Written by:
                        {%- for author in authors -%}
                          {{ author.name | link_to: author.system.url, class: 'author link' }}{% unless forloop.last %}, {% endunless %}
                        {%- endfor -%}
                      </div>
                    {%- endif -%}

                    {%- if narrators != blank -%}
                      <div class="object-meta">
                        Narrated by:
                        {%- for narrator in narrators -%}
                          {{ narrator.name | link_to: narrator.system.url, class: 'narrator link' }}{% unless forloop.last %}, {% endunless %}
                        {%- endfor -%}
                      </div>
                    {%- endif -%}

                    {%- if blurb != blank -%}
                      <div class="object-description">{{ blurb | truncate: 190 }}</div>
                    {%- endif -%}
                  </div>
                </li>
              {%- endfor -%}
            </ul>

            {%- render 'pagination', paginate: paginate, class: 'object-pagination' -%}
          {% endpaginate %}
        {%- else -%}
          {%- liquid
            assign page_size = section.settings.page_size | plus: 0
            if page_size < 1
              assign page_size = 25
            endif

            assign metaobject_type = blank
            assign source_values = blank
            assign page_param_name = 'directory_page'
            case object_type
              when 'authors'
                assign metaobject_type = 'author'
              when 'narrators'
                assign metaobject_type = 'narrator'
              when 'characters'
                assign metaobject_type = 'character'
                assign source_values = shop.metaobjects.character.values
              when 'publishers'
                assign metaobject_type = 'publisher'
                assign source_values = shop.metaobjects.publisher.values
              when 'overviews'
                assign metaobject_type = 'overview'
                assign source_values = shop.metaobjects.overview.values
              when 'audiogrammes'
                assign metaobject_type = 'audiogramme'
                assign source_values = shop.metaobjects.audiogramme.values
              when 'series'
                assign metaobject_type = 'series'
                assign source_values = shop.metaobjects.series.values
            endcase
          -%}

          {%- if metaobject_type == 'author' or metaobject_type == 'narrator' -%}
            {% paginate collections['audiobooks'].products by 250 %}
              {%- assign related_objects = null | sort -%}
              {%- for product in collections['audiobooks'].products -%}
                {%- if metaobject_type == 'author' -%}
                  {%- assign linked_objects = product.metafields.book.authors.value -%}
                {%- else -%}
                  {%- assign linked_objects = product.metafields.book.narrators.value -%}
                {%- endif -%}

                {%- if linked_objects != blank -%}
                  {%- assign related_objects = related_objects | concat: linked_objects -%}
                {%- endif -%}
              {%- endfor -%}
              {%- assign source_values = related_objects | uniq -%}
            {% endpaginate %}
          {%- endif -%}

          {%- capture object_records_raw -%}
            {%- for object in source_values -%}
              {%- assign object_name = object.name | default: object.title.value | strip -%}
              {%- if object_name == blank -%}
                {%- continue -%}
              {%- endif -%}

              {%- assign alpha_label = object_name | slice: 0, 1 | upcase -%}
              {%- assign object_name_downcase = object_name | downcase -%}

              {%- if metaobject_type == 'author' or metaobject_type == 'narrator' -%}
                {%- assign surname_key = object_name | split: ' ' | last | downcase -%}
                {%- assign sort_key = surname_key | append: ' ' | append: object_name_downcase -%}
              {%- else -%}
                {%- assign sort_key = object_name_downcase -%}
              {%- endif -%}

              {%- assign image = blank -%}
              {%- assign description = object.description | default: object.bio -%}
              {%- if object.logo != blank -%}
                {%- assign image = object.logo.value | default: object.logo -%}
              {%- elsif object.image != blank -%}
                {%- assign image = object.image.value | default: object.image -%}
              {%- elsif object.photos != blank -%}
                {%- assign image = object.photos.value | first -%}
              {%- elsif object.product != blank and object.product.value != blank -%}
                {%- assign image = object.product.value.featured_image -%}
              {%- endif -%}

              {%- assign object_link_class = object_type | append: ' link' -%}
              {%- capture object_markup -%}
                <li class="object-item" data-alpha-label="{{ alpha_label | escape }}" data-page="__PAGE__">
                  <a class="object-image" href="{{ object.system.url }}">
                    {% render 'person-avatar', metaobject: object, radius: section.settings.radius, max_width: 72, image_to_use: image, avatar_bg_color: section.settings.avatar_bg_color, avatar_display: section.settings.avatar_display, initials_color: section.settings.initials_color, initials_font_size: section.settings.initials_font_size %}
                  </a>
                  <div class="object-text">
                    <p class="object-title">
                      {{ object_name | link_to: object.system.url, class: object_link_class }}
                      {%- if metaobject_type == 'publisher' and object.collection.value != blank -%}
                        <span class="review">({{ 'view collection' | link_to: object.collection.value.url, class: 'link' }})</span>
                      {%- endif -%}
                    </p>
                    {%- if description != blank -%}
                      <div class="object-description">{{ description | metafield_tag | strip_html | truncate: 170 }}</div>
                    {%- endif -%}
                  </div>
                </li>
              {%- endcapture -%}

              {{ sort_key | replace: '[[[field]]]', '' | replace: '[[[row]]]', '' }}[[[field]]]{{ alpha_label | replace: '[[[field]]]', '' | replace: '[[[row]]]', '' }}[[[field]]]{{ object_markup | strip }}{% unless forloop.last %}[[[row]]]{% endunless %}
            {%- endfor -%}
          {%- endcapture -%}

          {%- assign object_records = object_records_raw | split: '[[[row]]]' | sort_natural -%}
          {%- assign object_count = object_records.size -%}
          {%- assign total_pages = object_count | plus: page_size | minus: 1 | divided_by: page_size -%}

          <div class="metaobjects-list-client" data-page-size="{{ page_size }}" data-total-pages="{{ total_pages }}">
            <ul class="object-list">
              {%- for object_record in object_records -%}
                {%- if object_record == blank -%}
                  {%- continue -%}
                {%- endif -%}

                {%- assign item_page = forloop.index0 | divided_by: page_size | plus: 1 -%}
                {%- assign record_parts = object_record | split: '[[[field]]]' -%}
                {%- assign object_markup = record_parts[2] | replace: '__PAGE__', item_page -%}
                {{ object_markup }}
              {%- endfor -%}
            </ul>

            <nav class="object-pagination" aria-label="Page navigation"></nav>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{%- unless object_type == 'audiobooks' -%}
  <script>
    (() => {
      const section = document.getElementById('shopify-section-{{ section.id }}');
      if (!section) return;

      const wrapper = section.querySelector('.metaobjects-list-client');
      if (!wrapper) return;

      const items = Array.from(section.querySelectorAll('.object-item[data-alpha-label]'));
      if (!items.length) return;
      const pageNav = section.querySelector('.object-pagination');
      if (!pageNav) return;

      const totalPages = Math.max(1, Number(wrapper.dataset.totalPages || 1));
      const currentUrl = new URL(window.location.href);
      const pageParamName = 'directory_page';
      const requestedPage = Number(currentUrl.searchParams.get(pageParamName) || 1);
      const currentPage = Math.min(Math.max(requestedPage, 1), totalPages);

      for (const item of items) {
        const itemPage = Number(item.dataset.page || 1);
        item.hidden = itemPage !== currentPage;
      }

      pageNav.innerHTML = '';
      const pageRange = Array.from({ length: totalPages }, (_, index) => index + 1);

      for (const pageNumber of pageRange) {
        const link = document.createElement('a');
        link.className = 'object-pagination__link';
        link.textContent = pageNumber;
        const linkUrl = new URL(currentUrl);
        linkUrl.searchParams.set(pageParamName, pageNumber);
        link.href = `${linkUrl.pathname}${linkUrl.search}`;

        if (pageNumber === currentPage) {
          link.classList.add('is-active');
          link.setAttribute('aria-current', 'page');
        }

        pageNav.appendChild(link);
      }
    })();
  </script>
{%- endunless -%}

{% schema %}
{
  "name": "Metaobjects list",
  "class": "shopify-section--logo-list",
  "tag": "section",
  "disabled_on": {
    "templates": ["password"],
    "groups": ["header", "custom.overlay"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Metaobjects",
      "info": "Paginated list of metaobjects."
    },
    {
      "type": "range",
      "id": "page_size",
      "label": "Page size",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 25
    },
    {
      "type": "select",
      "id": "object_type",
      "label": "Object type",
      "options": [
        {
          "value": "audiobooks",
          "label": "Audiobooks"
        },
        {
          "value": "authors",
          "label": "Authors"
        },
        {
          "value": "narrators",
          "label": "Narrators"
        },
        {
          "value": "characters",
          "label": "Characters"
        },
        {
          "value": "publishers",
          "label": "Publishers"
        },
        {
          "value": "overviews",
          "label": "Overviews"
        },
        {
          "value": "audiogrammes",
          "label": "Audiogrammes"
        },
        {
          "value": "series",
          "label": "Series"
        }
      ],
      "info": "Choose a metaobject to paginate over",
      "default": "authors"
    },
    {
      "type": "radio",
      "id": "avatar_display",
      "label": "Avatar display style",
      "default": "image",
      "options": [
        { "value": "image", "label": "Image" },
        { "value": "initials", "label": "Initials" },
        { "value": "placeholder", "label": "Placeholder" }
      ]
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 100,
      "max": 500,
      "step": 10,
      "unit": "px",
      "label": "Maximum width",
      "default": 200
    },
    {
      "type": "range",
      "id": "radius",
      "min": 0,
      "max": 50,
      "step": 10,
      "unit": "%",
      "label": "Image radius",
      "default": 30
    },
    {
      "type": "range",
      "id": "initials_font_size",
      "label": "Initials font size",
      "min": 5,
      "max": 200,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "color",
      "id": "initials_color",
      "label": "Initials color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "avatar_bg_color",
      "label": "Initials background",
      "default": "#ffffff"
    }
  ],
  "blocks": [

  ],
  "presets": [
    {
      "name": "Metaobjects list",
      "blocks": [
        
      ]
    }
  ]
}
{% endschema %}
