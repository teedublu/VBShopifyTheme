{%- liquid
  assign source_metaobject = metaobject
  if metaobject.system.type == 'read_along' and metaobject.audiogramme != blank and metaobject.audiogramme.value != blank
    assign source_metaobject = metaobject.audiogramme.value
  endif

  assign current_handle = source_metaobject.system.handle | default: metaobject.system.handle
  assign max_items = section.settings.max_items | default: 10
  assign shown_count = 0
  assign scroll_area_id = 'audiogramme-carousel-' | append: section.id
-%}

{%- render 'section-spacing-collapsing' -%}

<style>
  #shopify-section-{{ section.id }} {
    --sample-card-width: 56vw;
  }

  @media screen and (min-width: 700px) {
    #shopify-section-{{ section.id }} {
      --sample-card-width: 32vw;
    }
  }

  @media screen and (min-width: 1000px) {
    #shopify-section-{{ section.id }} {
      --sample-card-width: calc((var(--container-inner-width) - (var(--grid-gutter) * 4)) / 5);
    }
  }

  #shopify-section-{{ section.id }} .sample-carousel {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  #shopify-section-{{ section.id }} .sample-carousel__track {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: var(--sample-card-width);
    gap: 1rem;
  }

  #shopify-section-{{ section.id }} .sample-teaser {
    display: grid;
    gap: 0.65rem;
    color: inherit;
    text-decoration: none;
  }

  #shopify-section-{{ section.id }} .sample-teaser__thumb {
    position: relative;
    aspect-ratio: 16 / 9;
    border-radius: 14px;
    overflow: hidden;
    background: #f4f5f7;
  }

  #shopify-section-{{ section.id }} .sample-teaser__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #shopify-section-{{ section.id }} .sample-teaser__body {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.14rem;
  }

  #shopify-section-{{ section.id }} .sample-teaser__title {
    margin: 0;
    font-size: 0.88rem;
    line-height: 1.28;
    color: #101820;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .sample-teaser__meta {
    margin: 0;
    color: rgba(16, 24, 32, 0.72);
    font-size: 0.74rem;
    line-height: 1.25;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

<div {% render 'section-properties' %}>
  <div class="sample-carousel section-stack">
    {%- render 'section-header', heading: section.settings.title, content: section.settings.content, tag: 'h2' -%}

    <scroll-carousel selector=".sample-teaser" id="{{ scroll_area_id }}" class="scroll-area bleed is-scrollable" disable-preloading>
      <div class="sample-carousel__track">
          {%- for object in shop.metaobjects.audiogramme.values -%}
            {%- assign object_handle = object.system.handle -%}
            {%- if object_handle == current_handle -%}
              {%- continue -%}
            {%- endif -%}

            {%- assign object_product = blank -%}
            {%- if object.product != blank and object.product.value != blank -%}
              {%- assign object_product = object.product.value -%}
            {%- endif -%}
            {%- if object_product == blank -%}
              {%- assign object_product = all_products[object_handle] -%}
            {%- endif -%}

            {%- assign object_audiobook = shop.metaobjects.audiobook[object_handle] -%}
            {%- assign object_title = object_audiobook.title.value | default: object_product.title | default: object.name -%}
            {%- assign object_author = object_product.metafields.book.authors.value | first -%}
            {%- assign object_narrator = object_product.metafields.book.narrators.value | first -%}
            {%- assign object_description = object_audiobook.concise_blurb | default: object_audiobook.short_blurb -%}
            {%- assign object_thumbnail = object.thumbnail.value -%}
            {%- capture object_url -%}{% render 'audiogramme-url', handle: object_handle, kind: 'sample' %}{%- endcapture -%}

            {%- if object_title == blank -%}
              {%- continue -%}
            {%- endif -%}

            <a href="{{ object_url }}" class="sample-teaser snap-start">
              <div class="sample-teaser__thumb">
                {%- if object_thumbnail != blank -%}
                  {{ object_thumbnail | image_url: width: 720 | image_tag: loading: 'lazy', alt: object_title }}
                {%- elsif object_product.featured_image != blank -%}
                  {{ object_product.featured_image | image_url: width: 720 | image_tag: loading: 'lazy', alt: object_title }}
                {%- endif -%}
              </div>

              <div class="sample-teaser__body">
                <h3 class="sample-teaser__title">{{ object_title }}</h3>
                {%- if object_author != blank or object_narrator != blank -%}
                  <p class="sample-teaser__meta">
                    {%- if object_author != blank -%}{{ object_author.name }}{%- endif -%}
                    {%- if object_narrator != blank -%}
                      {%- if object_author != blank -%} · {% endif -%}
                      {{ object_narrator.name }}
                    {%- endif -%}
                  </p>
                {%- elsif object_description != blank -%}
                  <p class="sample-teaser__meta">{{ object_description | metafield_tag | strip_html | truncate: 52 }}</p>
                {%- endif -%}
              </div>
            </a>

            {%- assign shown_count = shown_count | plus: 1 -%}
            {%- if shown_count >= max_items -%}
              {%- break -%}
            {%- endif -%}
          {%- endfor -%}
      </div>
    </scroll-carousel>
  </div>
</div>

{% schema %}
{
  "name": "Audiobook Sample Carousel",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "More audiobook samples"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Content",
      "default": "<p>Find another story sample and keep listening.</p>"
    },
    {
      "type": "range",
      "id": "max_items",
      "label": "Maximum items",
      "min": 4,
      "max": 16,
      "step": 1,
      "default": 10
    }
  ]
}
{% endschema %}
