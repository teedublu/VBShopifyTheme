{%- assign chapters = metaobject.chapters.value | sort: 'index' %}
{%- if chapters.size>0 -%}
<style>

.chapters-container {
  display: grid;
  gap: 1rem;
}


ol.chapters-list {
  display: grid;
  grid-template-columns: repeat(1, minmax(0, 1fr));
  gap: 1rem;
  margin: 0;
  padding: 0;
  list-style: none;
}

@media screen and (min-width: 750px) {
  ol.chapters-list {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

ol.chapters-list li {
  padding: 1.1rem 1.2rem;
  border-radius: 22px;
  border: 1px solid rgba(22, 32, 72, 0.08);
  background: rgba(255, 255, 255, 0.82);
  box-shadow: 0 14px 34px rgba(22, 32, 72, 0.08);
}

.chapter-item b {
  display: block;
  margin-bottom: 0.55rem;
  font-size: 1.05rem;
  line-height: 1.35;
}

.chapter-content {
  text-align: left;
}

.chapter-content p:last-child {
  margin-bottom: 0;
}

</style>


    

<div {% render 'section-properties', tight: true, class: 'mobile_float' %}>
    <div class="section-stack">
        {%- render 'section-header', subheading: section.settings.subheading, heading: section.settings.heading, heading_color: section.settings.heading_color, heading_gradient: section.settings.heading_gradient, content: section.settings.content, link_text: section.settings.link_text, link_url: section.settings.link_url -%}

        <div class="chapters-container">
          <ol class="chapters-list">
            {%- for chapter in chapters -%}
              <li class="chapter-item">
                <div class="chapter-content">
                  {%- if chapter.label -%}
                    <b>{{ chapter.label }}</b>
                  {%- else -%}
                    <b>Chapter {{forloop.index}} : {{ chapter.title }}</b>
                  {%- endif -%}
                  {{ chapter.summary | metafield_tag }}
                </div>
              </li>
            {%- endfor -%}
          </ol>
        </div>
    </div>


</div>
{%- endif -%}
{% schema %}
{
    "name": "Audiobook Chapters",
      "settings": [
        {
          "type": "checkbox",
          "id": "full_width",
          "label": "Full width",
          "default": true
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Subheading",
          "default": "What's inside"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Chapters"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Content",
          "default": "<p>Here are the chapters in this audiobook.</p>"
        },
        {
          "type": "header",
          "content": "Section colors",
          "info": "Gradient replaces solid colors when set."
        },
        {
          "type": "color",
          "id": "background",
          "label": "Background"
        },
        {
          "type": "color_background",
          "id": "background_gradient",
          "label": "Background gradient"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text"
        },
        {
          "type": "color",
          "id": "heading_color",
          "label": "Heading color"
        },
        {
          "type": "color_background",
          "id": "heading_gradient",
          "label": "Heading gradient"
        }
      ],
    "blocks": [ ],
    "presets": [
        {
            "name": "Default Audiobook Chapters",
            "category": "Custom Content"
        }
    ]
}
{% endschema %}

