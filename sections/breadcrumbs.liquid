{%- render 'section-spacing-collapsing' -%}

<style>
  .breadcrumbs_section {
    padding-top: 1em;
    padding-bottom: 1em;
  }

  .breadcrumbs {
    margin: 0;
  }

  .breadcrumbs__list {
    list-style-type: none;
    margin: 0;
    padding: 0;
  }

  .breadcrumbs__item {
    display: inline-block;
  }

  .breadcrumbs__item:not(:last-child):after {
    border-style: solid;
    border-width: .10em .10em 0 0;
    content: '';
    display: inline-block;
    height: .20em;
    margin: 0 .20em;
    position: relative;
    transform: rotate(45deg);
    vertical-align: middle;
    width: .20em;
  }

  .breadcrumbs__link {
    text-decoration: underline;
  }

  .breadcrumbs__current {
    color: inherit;
    font-weight: normal;
    text-decoration: none;
  }

  .breadcrumbs__item:first-child .breadcrumbs__link {
    position: relative;
    padding-left: 20px;
    display: inline-flex;
    align-items: center;
  }

  .breadcrumbs__item:first-child .breadcrumbs__link::before {
    content: "\2302";
    font-size: 1.7em;
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-65%);
  }

  .breadcrumbs__item:first-child .breadcrumbs__link span {
    visibility: hidden;
    display: inline-block;
    width: 0;
    height: 0;
    overflow: hidden;
  }
</style>

{%- assign title = page.metafields.global.title_tag | default: page.title -%}

{%- assign metaobject_type = blank -%}
{%- if metaobject != blank -%}
  {%- assign metaobject_type = metaobject.system.type -%}
{%- endif -%}
{%- capture audiogramme_route_mode -%}{% render 'audiogramme-route-mode', metaobject: metaobject %}{%- endcapture -%}

{%- unless template == 'index' or template == 'cart' or template == 'list-collections' or template == '404' -%}
  {%- assign page_type = template | split: '.' | first -%}
  {%- assign page_subtype = template | split: '.' | last -%}

  {%- if page_type contains '/' -%}
    {%- assign page_subtype = page_type | split: '/' | last -%}
    {%- assign page_type = page_type | split: '/' | first -%}
  {%- endif -%}

  {%- liquid
    assign crumb_item_sep = '||'
    assign crumb_part_sep = '^^'

    assign crumbs = shop.secure_url | append: crumb_part_sep | append: 'Home'
    assign crumbs = crumbs | append: crumb_item_sep | append: pages['audiobook-library'].url | append: crumb_part_sep | append: 'Our Content'

    assign list_page = blank
    assign parent_page = blank
    assign parent_title = blank

    case page_type
      when 'page'
        unless page_subtype contains 'metaobjects-'
          case metaobject_type
            when 'audiobook'
              assign list_page = 'audiobooks'
            when 'audiogramme'
              if audiogramme_route_mode == 'read_along'
                assign list_page = 'read-alongs'
              else
                assign list_page = 'audiobook-samples'
              endif
            when 'series'
              assign list_page = 'audiobook-series'
            when 'character'
              assign list_page = 'audiobook-characters'
            when 'review'
              assign list_page = 'audiobooks'
            else
              if metaobject != blank
                assign list_page = 'audiobook-' | append: metaobject.system.type | append: 's'
              endif
          endcase

          if list_page != blank
            assign parent_page = pages[list_page]
            if parent_page != blank
              assign parent_title = parent_page.metafields.global.title_tag | default: parent_page.title
              assign crumbs = crumbs | append: crumb_item_sep | append: parent_page.url | append: crumb_part_sep | append: parent_title
            endif
          endif
        endunless

        assign crumbs = crumbs | append: crumb_item_sep | append: page.url | append: crumb_part_sep | append: title

      when 'product'
        case page_subtype
          when 'starter-pack-bundle'
            assign crumbs = shop.secure_url | append: crumb_part_sep | append: 'Home'
            assign crumbs = crumbs | append: crumb_item_sep | append: collections['voxblock-starter-pack-collection'].url | append: crumb_part_sep | append: collections['voxblock-starter-pack-collection'].title
          when 'audiobook'
            assign crumbs = shop.secure_url | append: crumb_part_sep | append: 'Home'
            assign crumbs = crumbs | append: crumb_item_sep | append: collections['audiobooks'].url | append: crumb_part_sep | append: collections['audiobooks'].title
          else
            if collection.url
              assign crumbs = crumbs | append: crumb_item_sep | append: collection.url | append: crumb_part_sep | append: collection.title
            endif
        endcase

        assign crumbs = crumbs | append: crumb_item_sep | append: product.url | append: crumb_part_sep | append: product.title

      when 'collection'
        assign crumbs = crumbs | append: crumb_item_sep | append: collections['audiobooks'].url | append: crumb_part_sep | append: collections['audiobooks'].title
        assign crumbs = crumbs | append: crumb_item_sep | append: collection.url | append: crumb_part_sep | append: collection.title

      when 'blog'
        assign crumbs = crumbs | append: crumb_item_sep | append: blog.url | append: crumb_part_sep | append: blog.title

      when 'article'
        assign crumbs = crumbs | append: crumb_item_sep | append: blog.url | append: crumb_part_sep | append: blog.title
        assign crumbs = crumbs | append: crumb_item_sep | append: article.url | append: crumb_part_sep | append: article.title

      when 'metaobject'
        assign title = metaobject.title | default: metaobject.name
        assign read_along_parent_title = blank
        assign read_along_parent_url = blank

        case metaobject_type
          when 'audiobook'
            assign list_page = 'audiobooks'
          when 'audiogramme'
            if audiogramme_route_mode == 'read_along'
              assign list_page = 'audiobooks'
              assign title = 'Read Along'
              assign read_along_source = metaobject
              assign read_along_handle = read_along_source.system.handle | default: metaobject.system.handle
              assign read_along_audiobook = shop.metaobjects.audiobook[read_along_handle]
              assign read_along_product = blank

              if read_along_source.product != blank and read_along_source.product.value != blank
                assign read_along_product = read_along_source.product.value
              endif

              if read_along_product == blank and read_along_audiobook != blank and read_along_audiobook.product != blank
                assign read_along_product = read_along_audiobook.product.value
              endif

              if read_along_product == blank
                assign read_along_product = all_products[read_along_handle]
              endif

              assign read_along_parent_title = read_along_source.name | default: read_along_audiobook.title.value | default: read_along_product.title
              assign read_along_parent_url = read_along_audiobook.system.url | default: read_along_product.url

              if read_along_handle contains 'paddington'
                assign read_along_parent_title = 'Paddington Bear'
              endif
            else
              assign list_page = 'audiobook-samples'
              assign title = metaobject.name | append: ' audiobook sample'
            endif
          when 'read_along'
            assign list_page = 'audiobooks'
            assign title = 'Read Along'

            if metaobject.audiogramme != blank and metaobject.audiogramme.value != blank
              assign read_along_source = metaobject.audiogramme.value
            else
              assign read_along_source = metaobject
            endif

            assign read_along_handle = read_along_source.system.handle | default: metaobject.system.handle
            assign read_along_audiobook = shop.metaobjects.audiobook[read_along_handle]
            assign read_along_product = blank

            if read_along_source.product != blank and read_along_source.product.value != blank
              assign read_along_product = read_along_source.product.value
            elsif metaobject.product != blank and metaobject.product.value != blank
              assign read_along_product = metaobject.product.value
            endif

            if read_along_product == blank and read_along_audiobook != blank and read_along_audiobook.product != blank
              assign read_along_product = read_along_audiobook.product.value
            endif

            if read_along_product == blank
              assign read_along_product = all_products[read_along_handle]
            endif

            assign read_along_parent_title = read_along_source.name | default: metaobject.name | default: read_along_audiobook.title.value | default: read_along_product.title
            assign read_along_parent_url = read_along_audiobook.system.url | default: read_along_product.url

            if read_along_handle contains 'paddington'
              assign read_along_parent_title = 'Paddington Bear'
            endif
          when 'series'
            assign list_page = 'audiobook-series'
          when 'overview'
            assign list_page = 'overviews'
          when 'review'
            assign list_page = 'audiobooks'
            assign title = metaobject.name | prepend: 'Review of '
          when 'character'
            assign list_page = 'audiobook-characters'
            assign title = metaobject.name
          else
            assign list_page = 'audiobook-' | append: page_subtype | append: 's'
        endcase

        if list_page != blank
          assign parent_page = pages[list_page]
          if parent_page != blank
            assign parent_title = parent_page.metafields.global.title_tag | default: parent_page.title
            if list_page == 'audiobooks' and read_along_parent_title != blank
              assign parent_title = 'Audiobooks'
            endif
            assign crumbs = crumbs | append: crumb_item_sep | append: parent_page.url | append: crumb_part_sep | append: parent_title
          endif
        endif

        if read_along_parent_title != blank and read_along_parent_url != blank
          assign crumbs = crumbs | append: crumb_item_sep | append: read_along_parent_url | append: crumb_part_sep | append: read_along_parent_title
        endif

        if metaobject_type == 'character' and metaobject.main_book.value != blank
          assign main_book = metaobject.main_book.value
          assign main_book_title = main_book.title | default: main_book.name

          if main_book.system.url != blank and main_book_title != blank
            assign crumbs = crumbs | append: crumb_item_sep | append: main_book.system.url | append: crumb_part_sep | append: main_book_title
          endif
        endif

        assign crumbs = crumbs | append: crumb_item_sep | append: metaobject.system.url | append: crumb_part_sep | append: title

      else
        assign crumbs = crumbs | append: crumb_item_sep | append: request.path | append: crumb_part_sep | append: page_title
    endcase

    assign gruffalo_overview_url = '/pages/overview/the-gruffalo'
    assign gruffalo_characters_url = '/pages/characters/the-gruffalo'
    assign gruffalo_audiobook_url = '/pages/audiobook/the-gruffalo'
    assign gruffalo_product_url = '/products/the-gruffalo'
    assign gruffalo_audiobooks_url = pages['audiobooks'].url | default: '/pages/audiobooks'

    assign gruffalo_crumbs = shop.secure_url | append: crumb_part_sep | append: 'Home'
    assign gruffalo_crumbs = gruffalo_crumbs | append: crumb_item_sep | append: pages['audiobook-library'].url | append: crumb_part_sep | append: 'Our Content'
    assign gruffalo_crumbs = gruffalo_crumbs | append: crumb_item_sep | append: gruffalo_audiobooks_url | append: crumb_part_sep | append: 'Audiobooks'

    if page_type == 'metaobject' and metaobject != blank
      assign gruffalo_current_title = metaobject.name.value | default: metaobject.name | default: title
      assign gruffalo_current_handle = metaobject.system.handle

      if read_along_handle != blank
        assign gruffalo_current_handle = read_along_handle
      endif

      assign gruffalo_character_page = false

      if metaobject_type == 'character' and template contains 'gruffalo'
        assign gruffalo_character_page = true
      elsif metaobject_type == 'character' and metaobject.main_book.value != blank
        assign gruffalo_character_book = metaobject.main_book.value

        if gruffalo_character_book.system.handle == 'the-gruffalo'
          assign gruffalo_character_page = true
        endif
      endif

      if metaobject_type == 'overview' and metaobject.system.handle == 'the-gruffalo'
        assign crumbs = gruffalo_crumbs | append: crumb_item_sep | append: gruffalo_audiobook_url | append: crumb_part_sep | append: 'The Gruffalo'
        assign crumbs = crumbs | append: crumb_item_sep | append: gruffalo_overview_url | append: crumb_part_sep | append: 'Overview'
      elsif metaobject_type == 'characters' and metaobject.system.handle == 'the-gruffalo'
        assign crumbs = gruffalo_crumbs | append: crumb_item_sep | append: gruffalo_audiobook_url | append: crumb_part_sep | append: 'The Gruffalo'
        assign crumbs = crumbs | append: crumb_item_sep | append: gruffalo_characters_url | append: crumb_part_sep | append: 'Characters'
      elsif gruffalo_character_page
        assign crumbs = gruffalo_crumbs | append: crumb_item_sep | append: gruffalo_audiobook_url | append: crumb_part_sep | append: 'The Gruffalo'
        assign crumbs = crumbs | append: crumb_item_sep | append: gruffalo_characters_url | append: crumb_part_sep | append: 'Characters'
        assign crumbs = crumbs | append: crumb_item_sep | append: metaobject.system.url | append: crumb_part_sep | append: gruffalo_current_title
      elsif metaobject_type == 'audiobook' and metaobject.system.handle == 'the-gruffalo'
        assign crumbs = gruffalo_crumbs | append: crumb_item_sep | append: gruffalo_audiobook_url | append: crumb_part_sep | append: 'The Gruffalo'
      elsif metaobject_type == 'read_along' and gruffalo_current_handle == 'the-gruffalo'
        assign crumbs = gruffalo_crumbs | append: crumb_item_sep | append: gruffalo_audiobook_url | append: crumb_part_sep | append: 'The Gruffalo'
        assign crumbs = crumbs | append: crumb_item_sep | append: metaobject.system.url | append: crumb_part_sep | append: 'Read Along'
      elsif metaobject_type == 'audiogramme' and gruffalo_current_handle == 'the-gruffalo'
        assign crumbs = gruffalo_crumbs | append: crumb_item_sep | append: gruffalo_audiobook_url | append: crumb_part_sep | append: 'The Gruffalo'

        if audiogramme_route_mode == 'read_along'
          assign crumbs = crumbs | append: crumb_item_sep | append: metaobject.system.url | append: crumb_part_sep | append: 'Read Along'
        else
          assign crumbs = crumbs | append: crumb_item_sep | append: metaobject.system.url | append: crumb_part_sep | append: 'Sample'
        endif
      endif
    elsif page_type == 'product' and product.handle == 'the-gruffalo'
      assign crumbs = gruffalo_crumbs | append: crumb_item_sep | append: gruffalo_audiobook_url | append: crumb_part_sep | append: 'The Gruffalo'
      assign crumbs = crumbs | append: crumb_item_sep | append: gruffalo_product_url | append: crumb_part_sep | append: 'Buy The Gruffalo'
    endif

    assign crumb_list = crumbs | split: crumb_item_sep
  -%}

  <div {% render 'section-properties', tight: true, class: 'breadcrumbs_section' %}>
    <nav class="breadcrumbs" role="navigation" aria-label="Breadcrumbs">
      <ol class="breadcrumbs__list">
        {%- for crumb_pair in crumb_list -%}
          {%- assign crumb = crumb_pair | split: crumb_part_sep -%}
          {%- assign link = crumb[0] -%}
          {%- assign text = crumb[1] -%}

          <li class="breadcrumbs__item">
            {% if forloop.last %}
              <span class="breadcrumbs__current">{{ text }}</span>
            {% else %}
              <a href="{{ link }}" class="breadcrumbs__link">
                <span>{{ text }}</span>
              </a>
            {% endif %}
          </li>
        {%- endfor -%}
      </ol>
    </nav>
  </div>

  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {%- for crumb_pair in crumb_list -%}
          {%- assign c = crumb_pair | split: crumb_part_sep -%}
          {%- assign link = c[0] -%}

          {%- unless link contains 'voxblock.co.uk' -%}
            {%- assign link = link | prepend: 'https://voxblock.co.uk' -%}
          {%- endunless -%}

          {
            "@type": "ListItem",
            "position": {{ forloop.index }},
            "name": {{ c[1] | json }},
            "item": {{ link | json }}
          }{%- unless forloop.last -%},{%- endunless -%}
        {%- endfor -%}
      ]
    }
  </script>
{%- endunless -%}

{% schema %}
{
  "name": "Breadcrumb list",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading"
    }
  ],
  "presets": [
    {
      "name": "Breadcrumbs",
      "settings": {
        "heading": "Breadcrumbs"
      }
    }
  ]
}
{% endschema %}
