{%- liquid
  assign active_path = request.path
  assign primary_link = section.settings.primary_link
-%}

<section
  class="story-hub-results"
  {% if section.settings.anchor_id != blank %}
    id="{{ section.settings.anchor_id | escape }}"
    style="scroll-margin-top: calc(var(--header-height) + 24px)"
  {% endif %}
>
  <div class="story-hub-results__inner">
    <div class="story-hub-results__tabs" aria-label="{{ section.settings.title | escape }} page links">
      {%- for block in section.blocks -%}
        {%- assign item_link = block.settings.link -%}
        {%- assign is_active = false -%}

        {%- if item_link == active_path -%}
          {%- assign is_active = true -%}
        {%- endif -%}

        {%- if item_link != blank and block.settings.hide_from_tabs != true -%}
          <a class="story-hub-results__tab {% if is_active %}is-active{% endif %}" href="{{ item_link }}" {{ block.shopify_attributes }}>
            {{ block.settings.tab_label | default: block.settings.title | escape }}
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="story-hub-results__heading">
      {%- if section.settings.eyebrow != blank -%}
        <p class="story-hub-results__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}

      {%- if section.settings.title != blank -%}
        <h2>{{ section.settings.title | escape }}</h2>
      {%- endif -%}

      {%- if section.settings.content != blank -%}
        <div class="story-hub-results__content rte">
          {{ section.settings.content }}
        </div>
      {%- endif -%}
    </div>

    <div class="story-hub-results__layout">
      {%- if section.settings.primary_image != blank or section.settings.primary_image_url != blank or section.settings.primary_title != blank -%}
        {%- if primary_link != blank -%}
          <a class="story-hub-results__feature" href="{{ primary_link }}">
        {%- else -%}
          <div class="story-hub-results__feature">
        {%- endif -%}

          <div class="story-hub-results__feature-media">
            {%- if section.settings.primary_image != blank -%}
              {{ section.settings.primary_image | image_url: width: 1200 | image_tag: loading: 'lazy', widths: '360, 540, 720, 900, 1200', sizes: '(min-width: 990px) 44vw, 100vw', alt: section.settings.primary_title }}
            {%- elsif section.settings.primary_image_url != blank -%}
              <img src="{{ section.settings.primary_image_url | escape }}" alt="{{ section.settings.primary_title | escape }}" loading="lazy">
            {%- endif -%}
          </div>

          <div class="story-hub-results__feature-body">
            {%- if section.settings.primary_label != blank -%}
              <span>{{ section.settings.primary_label | escape }}</span>
            {%- endif -%}

            {%- if section.settings.primary_title != blank -%}
              <strong>{{ section.settings.primary_title | escape }}</strong>
            {%- endif -%}

            {%- if section.settings.primary_meta != blank -%}
              <p>{{ section.settings.primary_meta | escape }}</p>
            {%- endif -%}
          </div>

        {%- if primary_link != blank -%}
          </a>
        {%- else -%}
          </div>
        {%- endif -%}
      {%- endif -%}

      <div class="story-hub-results__cards">
        {%- for block in section.blocks -%}
          {%- assign item_link = block.settings.link -%}
          {%- assign card_classes = 'story-hub-results__card' -%}

          {%- if block.settings.emphasis == 'strong' -%}
            {%- assign card_classes = card_classes | append: ' story-hub-results__card--strong' -%}
          {%- elsif block.settings.emphasis == 'wide' -%}
            {%- assign card_classes = card_classes | append: ' story-hub-results__card--wide' -%}
          {%- endif -%}

          {%- if block.settings.compact_image -%}
            {%- assign card_classes = card_classes | append: ' story-hub-results__card--compact-image' -%}
          {%- endif -%}

          {%- if item_link != blank -%}
            <a class="{{ card_classes }}" href="{{ item_link }}" {{ block.shopify_attributes }}>
          {%- else -%}
            <article class="{{ card_classes }}" {{ block.shopify_attributes }}>
          {%- endif -%}

            {%- if block.settings.image != blank or block.settings.image_url != blank -%}
              <div class="story-hub-results__card-media">
                {%- if block.settings.image != blank -%}
                  {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', widths: '180, 240, 360, 480, 600', sizes: '(min-width: 990px) 18vw, 38vw', alt: block.settings.title }}
                {%- else -%}
                  <img src="{{ block.settings.image_url | escape }}" alt="{{ block.settings.title | escape }}" loading="lazy">
                {%- endif -%}
              </div>
            {%- endif -%}

            <div class="story-hub-results__card-body">
              {%- if block.settings.badge != blank -%}
                <span class="story-hub-results__badge">{{ block.settings.badge | escape }}</span>
              {%- endif -%}

              {%- if block.settings.title != blank -%}
                <h3>{{ block.settings.title | escape }}</h3>
              {%- endif -%}

              {%- if block.settings.description != blank -%}
                <p>{{ block.settings.description | escape }}</p>
              {%- endif -%}

              {%- if block.settings.link_text != blank -%}
                <span class="story-hub-results__link-text">{{ block.settings.link_text | escape }}</span>
              {%- endif -%}
            </div>

          {%- if item_link != blank -%}
            </a>
          {%- else -%}
            </article>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} {
    --story-hub-background: {{ section.settings.background | default: '#ffffff' }};
    --story-hub-panel: {{ section.settings.panel_background | default: '#eef8e8' }};
    --story-hub-accent: {{ section.settings.accent_color | default: '#197177' }};
    --story-hub-text: {{ section.settings.text_color | default: '#22302f' }};
  }

  #shopify-section-{{ section.id }} .story-hub-results {
    padding: 28px 0;
    background: var(--story-hub-background);
    color: var(--story-hub-text);
  }

  #shopify-section-{{ section.id }} .story-hub-results__inner {
    width: min({% if section.settings.full_width %}100%{% else %}var(--container-max-width){% endif %}, calc(100vw - 32px));
    margin: 0 auto;
  }

  #shopify-section-{{ section.id }} .story-hub-results__tabs {
    display: flex;
    gap: 18px;
    overflow-x: auto;
    border-bottom: 1px solid rgba(34, 48, 47, 0.16);
    scrollbar-width: none;
  }

  #shopify-section-{{ section.id }} .story-hub-results__tabs::-webkit-scrollbar {
    display: none;
  }

  #shopify-section-{{ section.id }} .story-hub-results__tab {
    flex: 0 0 auto;
    padding: 0 0 9px;
    border-bottom: 3px solid transparent;
    color: rgba(34, 48, 47, 0.72);
    font-size: 0.92rem;
    font-weight: 700;
    text-decoration: none;
    white-space: nowrap;
  }

  #shopify-section-{{ section.id }} .story-hub-results__tab:hover,
  #shopify-section-{{ section.id }} .story-hub-results__tab.is-active {
    border-color: var(--story-hub-accent);
    color: var(--story-hub-text);
  }

  #shopify-section-{{ section.id }} .story-hub-results__heading {
    max-width: 780px;
    padding: 22px 0 18px;
  }

  #shopify-section-{{ section.id }} .story-hub-results__eyebrow {
    margin: 0 0 8px;
    color: var(--story-hub-accent);
    font-weight: 800;
  }

  #shopify-section-{{ section.id }} .story-hub-results__heading h2 {
    margin: 0;
    font-size: clamp(1.55rem, 3.5vw, 2.35rem);
    line-height: 1.08;
  }

  #shopify-section-{{ section.id }} .story-hub-results__content {
    margin-top: 12px;
    color: rgba(34, 48, 47, 0.78);
  }

  #shopify-section-{{ section.id }} .story-hub-results__layout {
    display: grid;
    grid-template-columns: minmax(280px, 0.8fr) minmax(0, 1.2fr);
    gap: 14px;
    align-items: stretch;
  }

  #shopify-section-{{ section.id }} .story-hub-results__feature,
  #shopify-section-{{ section.id }} .story-hub-results__card {
    display: flex;
    overflow: hidden;
    border-radius: 8px;
    background: var(--story-hub-panel);
    color: inherit;
    text-decoration: none;
  }

  #shopify-section-{{ section.id }} .story-hub-results__feature {
    min-height: 240px;
    flex-direction: column;
  }

  #shopify-section-{{ section.id }} .story-hub-results__feature-media {
    min-height: 150px;
    background: rgba(25, 113, 119, 0.08);
  }

  #shopify-section-{{ section.id }} .story-hub-results__feature-media img,
  #shopify-section-{{ section.id }} .story-hub-results__card-media img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  #shopify-section-{{ section.id }} .story-hub-results__feature-body {
    display: grid;
    gap: 4px;
    padding: 14px 16px 16px;
  }

  #shopify-section-{{ section.id }} .story-hub-results__feature-body span,
  #shopify-section-{{ section.id }} .story-hub-results__badge {
    color: var(--story-hub-accent);
    font-size: 0.82rem;
    font-weight: 800;
  }

  #shopify-section-{{ section.id }} .story-hub-results__feature-body strong {
    font-size: 1.12rem;
    line-height: 1.2;
  }

  #shopify-section-{{ section.id }} .story-hub-results__feature-body p,
  #shopify-section-{{ section.id }} .story-hub-results__card-body p {
    margin: 0;
    color: rgba(34, 48, 47, 0.76);
  }

  #shopify-section-{{ section.id }} .story-hub-results__cards {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
  }

  #shopify-section-{{ section.id }} .story-hub-results__card {
    min-height: 112px;
    flex-direction: row;
    transition: transform 160ms ease, box-shadow 160ms ease;
  }

  #shopify-section-{{ section.id }} .story-hub-results__card:hover,
  #shopify-section-{{ section.id }} .story-hub-results__feature:hover {
    transform: translateY(-2px);
    box-shadow: 0 14px 34px rgba(18, 50, 79, 0.12);
  }

  #shopify-section-{{ section.id }} .story-hub-results__card--wide {
    grid-column: 1 / -1;
  }

  #shopify-section-{{ section.id }} .story-hub-results__card--strong {
    background: #fff7f0;
  }

  #shopify-section-{{ section.id }} .story-hub-results__card-media {
    flex: 0 0 72px;
    aspect-ratio: 1;
    background: rgba(25, 113, 119, 0.08);
  }

  #shopify-section-{{ section.id }} .story-hub-results__card--compact-image .story-hub-results__card-media {
    flex-basis: 46px;
    width: 46px;
    height: 46px;
    border-radius: 6px;
    margin: 12px 0 0 12px;
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .story-hub-results__card--compact-image .story-hub-results__card-body {
    align-content: start;
    padding-top: 14px;
  }

  #shopify-section-{{ section.id }} .story-hub-results__card--compact-image .story-hub-results__badge,
  #shopify-section-{{ section.id }} .story-hub-results__card--compact-image h3 {
    min-height: 0;
  }

  #shopify-section-{{ section.id }} .story-hub-results__card--compact-image .story-hub-results__card-body p,
  #shopify-section-{{ section.id }} .story-hub-results__card--compact-image .story-hub-results__link-text {
    grid-column: 1 / -1;
  }

  #shopify-section-{{ section.id }} .story-hub-results__card-body {
    display: grid;
    align-content: center;
    gap: 5px;
    min-width: 0;
    padding: 12px 14px;
  }

  #shopify-section-{{ section.id }} .story-hub-results__card-body h3 {
    margin: 0;
    font-size: 0.98rem;
    line-height: 1.22;
  }

  #shopify-section-{{ section.id }} .story-hub-results__card-body p {
    font-size: 0.86rem;
    line-height: 1.35;
    overflow-wrap: anywhere;
  }

  #shopify-section-{{ section.id }} .story-hub-results__link-text {
    margin-top: 2px;
    color: var(--story-hub-accent);
    font-size: 0.85rem;
    font-weight: 800;
  }

  @media screen and (max-width: 989px) {
    #shopify-section-{{ section.id }} .story-hub-results__layout {
      grid-template-columns: 1fr;
    }

    #shopify-section-{{ section.id }} .story-hub-results__cards {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media screen and (max-width: 699px) {
    #shopify-section-{{ section.id }} .story-hub-results {
      padding: 24px 0;
    }

    #shopify-section-{{ section.id }} .story-hub-results__tabs {
      gap: 18px;
    }

    #shopify-section-{{ section.id }} .story-hub-results__cards {
      grid-template-columns: 1fr;
    }

    #shopify-section-{{ section.id }} .story-hub-results__card-media {
      flex-basis: 64px;
    }

    #shopify-section-{{ section.id }} .story-hub-results__feature {
      min-height: 0;
    }
  }
</style>

{% schema %}
{
  "name": "Story hub results",
  "class": "shopify-section--story-hub-results",
  "settings": [
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width",
      "default": false
    },
    {
      "type": "text",
      "id": "anchor_id",
      "label": "Anchor ID"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Explore this title"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "The story, audiobook and character pages"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Content",
      "default": "<p>Choose the page that matches what you want to know next.</p>"
    },
    {
      "type": "image_picker",
      "id": "primary_image",
      "label": "Primary image"
    },
    {
      "type": "text",
      "id": "primary_image_url",
      "label": "Primary image URL"
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary link"
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary label",
      "default": "Audiobook"
    },
    {
      "type": "text",
      "id": "primary_title",
      "label": "Primary title",
      "default": "The Gruffalo on Voxblock"
    },
    {
      "type": "text",
      "id": "primary_meta",
      "label": "Primary meta",
      "default": "A screen-free way for children to listen independently."
    },
    {
      "type": "color",
      "id": "background",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "panel_background",
      "label": "Panel background",
      "default": "#eef8e8"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent",
      "default": "#197177"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#22302f"
    }
  ],
  "blocks": [
    {
      "type": "page_card",
      "name": "Page card",
      "settings": [
        {
          "type": "text",
          "id": "tab_label",
          "label": "Tab label"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "text",
          "id": "link_text",
          "label": "Link text",
          "default": "Open page"
        },
        {
          "type": "checkbox",
          "id": "hide_from_tabs",
          "label": "Hide from top tabs",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "compact_image",
          "label": "Compact image",
          "default": false
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "image_url",
          "label": "Image URL"
        },
        {
          "type": "select",
          "id": "emphasis",
          "label": "Emphasis",
          "options": [
            {
              "value": "normal",
              "label": "Normal"
            },
            {
              "value": "strong",
              "label": "Strong"
            },
            {
              "value": "wide",
              "label": "Wide"
            }
          ],
          "default": "normal"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Story hub results"
    }
  ]
}
{% endschema %}
