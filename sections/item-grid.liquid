{% liquid
  assign source_mode = section.settings.source_mode
  assign items_limit = section.settings.items_limit
%}

<section class="item-grid-section">
  <div class="page-width">
    {% if section.settings.heading != blank or section.settings.intro != blank %}
      <div class="item-grid-section__header">
        {% if section.settings.heading != blank %}
          <h2 class="item-grid-section__heading">{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.intro != blank %}
          <div class="item-grid-section__intro rte">
            {{ section.settings.intro }}
          </div>
        {% endif %}
      </div>
    {% endif %}

    <div class="item-grid-section__grid">

      {% if source_mode == 'metaobject_list' and section.settings.metaobject_items != blank %}
        {% for item in section.settings.metaobject_items limit: items_limit %}
          {% liquid
            assign item_title = item.name.value | default: item.title.value
            assign item_description = item.description.value | default: item.summary.value
            assign item_image = item.photos.value | first | default: 'collection-apparel-1'
            assign item_page = item.product.url
            assign item_url = item.system.handle

            if item_page != blank
              assign item_link = item_page.url
            elsif item_url != blank
              assign item_link = item_url
            else
              assign item_link = blank
            endif
          %}

          <article class="item-grid-card">
            {% if item_link != blank %}
              <a class="item-grid-card__inner item-grid-card__inner--linked" href="{{ item_link }}">
            {% else %}
              <div class="item-grid-card__inner">
            {% endif %}

              {% if item_image != blank %}
                <div class="item-grid-card__image-wrap">
                  {{
                    item_image
                    | image_url: width: 800
                    | image_tag:
                      class: 'item-grid-card__image',
                      loading: 'lazy',
                      widths: '240, 360, 480, 720, 800',
                      sizes: '(min-width: 990px) 25vw, (min-width: 750px) 33vw, 100vw',
                      alt: item_title
                  }}
                </div>
              {% endif %}

              <div class="item-grid-card__content">
                {% if item_title != blank %}
                  <h3 class="item-grid-card__title">{{ item_title }}</h3>
                {% endif %}

                {% if item_description != blank %}
                  <div class="item-grid-card__description rte">
                    {{ item_description }}
                  </div>
                {% endif %}

                {% if item_link != blank and section.settings.button_label != blank %}
                  <span class="item-grid-card__button">{{ section.settings.button_label }}</span>
                {% endif %}
              </div>

            {% if item_link != blank %}
              </a>
            {% else %}
              </div>
            {% endif %}
          </article>
        {% endfor %}

      {% elsif source_mode == 'product_list' and section.settings.product_items != blank %}
        {% for product in section.settings.product_items limit: items_limit %}
          <article class="item-grid-card">
            <a class="item-grid-card__inner item-grid-card__inner--linked" href="{{ product.url }}">
              {% if product.featured_image != blank %}
                <div class="item-grid-card__image-wrap">
                  {{
                    product.featured_image
                    | image_url: width: 800
                    | image_tag:
                      class: 'item-grid-card__image',
                      loading: 'lazy',
                      widths: '240, 360, 480, 720, 800',
                      sizes: '(min-width: 990px) 25vw, (min-width: 750px) 33vw, 100vw',
                      alt: product.title
                  }}
                </div>
              {% endif %}

              <div class="item-grid-card__content">
                <h3 class="item-grid-card__title">{{ product.title }}</h3>

                {% if product.description != blank %}
                  <div class="item-grid-card__description rte">
                    {{ product.description | strip_html | truncatewords: 24 }}
                  </div>
                {% endif %}

                {% if section.settings.button_label != blank %}
                  <span class="item-grid-card__button">{{ section.settings.button_label }}</span>
                {% endif %}
              </div>
            </a>
          </article>
        {% endfor %}

      {% else %}
        {% for block in section.blocks limit: items_limit %}
          <article class="item-grid-card" {{ block.shopify_attributes }}>
            {% assign item_link = block.settings.link %}

            {% if item_link != blank %}
              <a class="item-grid-card__inner item-grid-card__inner--linked" href="{{ item_link }}">
            {% else %}
              <div class="item-grid-card__inner">
            {% endif %}

              {% if block.settings.image != blank %}
                <div class="item-grid-card__image-wrap">
                  {{
                    block.settings.image
                    | image_url: width: 800
                    | image_tag:
                      class: 'item-grid-card__image',
                      loading: 'lazy',
                      widths: '240, 360, 480, 720, 800',
                      sizes: '(min-width: 990px) 25vw, (min-width: 750px) 33vw, 100vw',
                      alt: block.settings.title
                  }}
                </div>
              {% endif %}

              <div class="item-grid-card__content">
                {% if block.settings.title != blank %}
                  <h3 class="item-grid-card__title">{{ block.settings.title }}</h3>
                {% endif %}

                {% if block.settings.description != blank %}
                  <div class="item-grid-card__description rte">
                    {{ block.settings.description }}
                  </div>
                {% endif %}

                {% if item_link != blank and section.settings.button_label != blank %}
                  <span class="item-grid-card__button">{{ section.settings.button_label }}</span>
                {% endif %}
              </div>

            {% if item_link != blank %}
              </a>
            {% else %}
              </div>
            {% endif %}
          </article>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

<style>
  .item-grid-section {
    padding: 48px 0;
  }

  .item-grid-section__header {
    max-width: 760px;
    margin: 0 auto 32px;
    text-align: center;
  }

  .item-grid-section__heading {
    margin: 0 0;
  }

  .item-grid-section__grid {
    display: grid;
    grid-template-columns: repeat(1, minmax(0, 1fr));
    gap: 24px;
  }

  @media screen and (min-width: 750px) {
    .item-grid-section__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media screen and (min-width: 990px) {
    .item-grid-section__grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }

  .item-grid-card__inner {
    display: flex;
    flex-direction: column;
    height: 100%;
    overflow: hidden;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 16px;
    background: rgb(var(--color-background));
    text-decoration: none;
    color: inherit;
  }

  .item-grid-card__inner--linked {
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .item-grid-card__inner--linked:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
  }

  .item-grid-card__image-wrap {
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: rgba(0, 0, 0, 0.03);
  }

  .item-grid-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .item-grid-card__content {
    display: flex;
    flex-direction: column;
    flex: 1 1 auto;
    padding: 20px;
  }

  .item-grid-card__title {
    margin: 0 0 10px;
  }

  .item-grid-card__description {
    margin-bottom: 16px;
  }

  .item-grid-card__button {
    margin-top: auto;
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
</style>

{% schema %}
{
  "name": "Item grid",
  "tag": "section",
  "class": "section section-item-grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Meet the characters"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "Intro",
      "default": "<p>Explore the main characters and learn more about their personalities and roles in the story.</p>"
    },
    {
      "type": "select",
      "id": "source_mode",
      "label": "Content source",
      "default": "blocks",
      "options": [
        { "value": "blocks", "label": "Manual blocks" },
        { "value": "metaobject_list", "label": "Metaobject list" },
        { "value": "product_list", "label": "Product list" }
      ]
    },
    {
      "type": "metaobject_list",
      "id": "metaobject_items",
      "label": "Metaobject items",
      "metaobject_type": "character",
      "limit": 12
    },
    {
      "type": "product_list",
      "id": "product_items",
      "label": "Product items",
      "limit": 12
    },
    {
      "type": "range",
      "id": "items_limit",
      "label": "Maximum items to show",
      "min": 1,
      "max": 12,
      "step": 1,
      "default": 4
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Read more"
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Manual item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Mouse"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description",
          "default": "<p>Mouse is clever, brave and resourceful, using quick thinking to outsmart danger.</p>"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Item grid"
    }
  ]
}
{% endschema %}