{% comment %}
  Section: Item grid
  Use for characters, books, authors, etc.
{% endcomment %}

<section class="item-grid-section">
  <div class="page-width">
    {% if section.settings.heading != blank %}
      <div class="item-grid-section__header">
        <h2 class="item-grid-section__heading">{{ section.settings.heading }}</h2>
        {% if section.settings.intro != blank %}
          <div class="item-grid-section__intro rte">
            {{ section.settings.intro }}
          </div>
        {% endif %}
      </div>
    {% endif %}

    {% if section.blocks.size > 0 %}
      <div class="item-grid-section__grid">
        {% for block in section.blocks %}
          <article class="item-grid-card" {{ block.shopify_attributes }}>
            {% assign item_link = block.settings.link %}
            {% assign item_title = block.settings.title %}
            {% assign item_description = block.settings.description %}
            {% assign item_button_label = block.settings.button_label %}

            {% if item_link != blank %}
              <a class="item-grid-card__inner item-grid-card__inner--linked" href="{{ item_link }}">
            {% else %}
              <div class="item-grid-card__inner">
            {% endif %}

              {% if block.settings.image != blank %}
                <div class="item-grid-card__image-wrap">
                  {{
                    block.settings.image
                    | image_url: width: 800
                    | image_tag:
                      class: 'item-grid-card__image',
                      loading: 'lazy',
                      widths: '240, 360, 480, 720, 800',
                      sizes: '(min-width: 990px) 25vw, (min-width: 750px) 33vw, 100vw',
                      alt: item_title
                  }}
                </div>
              {% endif %}

              <div class="item-grid-card__content">
                {% if item_title != blank %}
                  <h3 class="item-grid-card__title">{{ item_title }}</h3>
                {% endif %}

                {% if item_description != blank %}
                  <div class="item-grid-card__description rte">
                    {{ item_description }}
                  </div>
                {% endif %}

                {% if item_link != blank and item_button_label != blank %}
                  <span class="item-grid-card__button">
                    {{ item_button_label }}
                  </span>
                {% endif %}
              </div>

            {% if item_link != blank %}
              </a>
            {% else %}
              </div>
            {% endif %}
          </article>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

<style>
  .item-grid-section {
    padding: 48px 0;
  }

  .item-grid-section__header {
    max-width: 760px;
    margin: 0 auto 32px;
    text-align: center;
  }

  .item-grid-section__heading {
    margin: 0 0 12px;
  }

  .item-grid-section__intro {
    margin: 0;
  }

  .item-grid-section__grid {
    display: grid;
    grid-template-columns: repeat(1, minmax(0, 1fr));
    gap: 24px;
  }

  @media screen and (min-width: 750px) {
    .item-grid-section__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media screen and (min-width: 990px) {
    .item-grid-section__grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }

  .item-grid-card {
    height: 100%;
  }

  .item-grid-card__inner {
    display: flex;
    flex-direction: column;
    height: 100%;
    overflow: hidden;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 16px;
    background: rgb(var(--color-background));
    text-decoration: none;
    color: inherit;
  }

  .item-grid-card__inner--linked {
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .item-grid-card__inner--linked:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
  }

  .item-grid-card__image-wrap {
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: rgba(0, 0, 0, 0.03);
  }

  .item-grid-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .item-grid-card__content {
    display: flex;
    flex-direction: column;
    flex: 1 1 auto;
    padding: 20px;
  }

  .item-grid-card__title {
    margin: 0 0 10px;
  }

  .item-grid-card__description {
    margin-bottom: 16px;
  }

  .item-grid-card__button {
    margin-top: auto;
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
</style>

{% schema %}
{
  "name": "Item grid",
  "tag": "section",
  "class": "section section-item-grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Meet the characters"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "Intro",
      "default": "<p>Explore the main characters and learn more about their personalities and roles in the story.</p>"
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Mouse"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description",
          "default": "<p>Mouse is clever, brave and resourceful, using quick thinking to outsmart danger.</p>"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Read more"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Item grid",
      "blocks": [
        {
          "type": "item"
        },
        {
          "type": "item"
        },
        {
          "type": "item"
        },
        {
          "type": "item"
        }
      ]
    }
  ]
}
{% endschema %}