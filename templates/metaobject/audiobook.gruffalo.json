      "blocks": {
        "listen": {
          "type": "item",
          "settings": {
            "title": "How do children listen to The Gruffalo audiobook?",
            "check_for_text": "Title",
            "check_for_richtext": "",
            "content": "<p>Children place the physical Gruffalo audiobook on the Voxblock player and press play. There is no app, tablet, phone or Wi-Fi setup needed.</p>",
            "use_metaobject_characters": false
          }
        },
        "need_player": {
          "type": "item",
          "settings": {
            "title": "Do I need a Voxblock player?",
            "check_for_text": "Title",
            "check_for_richtext": "",
            "content": "<p>Yes. Voxblock audiobooks are designed to play on the Voxblock player. If you already have a player, you can add The Gruffalo as another physical story block.</p>",
            "use_metaobject_characters": false
          }
        },
        "age": {
          "type": "item",
          "settings": {
            "title": "What age is The Gruffalo audiobook for?",
            "check_for_text": "Title",
            "check_for_richtext": "",
            "content": "<p>The story is most often enjoyed by children in the early picture-book years, roughly ages 3 to 7, though older children may still enjoy the rhyme and familiar characters.</p>",
            "use_metaobject_characters": false
          }
        },
        "details": {
          "type": "item",
          "settings": {
            "title": "Who narrates The Gruffalo audiobook and how long is it?",
            "check_for_text": "Title",
            "check_for_richtext": "",
            "content": "<p>The Gruffalo audiobook is narrated by Imelda Staunton and runs for about 25 minutes. You can also check the Runtime & details section on this page for the latest product data.</p>",
            "use_metaobject_characters": false
          }
        },
