    "rich_text_story_beats": {
      "type": "rich-text",
      "blocks": {
        "subheading_story_shape": {
          "type": "subheading",
          "settings": {
            "text": "Story shape"
          }
        },
        "heading_story_beats": {
          "type": "heading",
          "settings": {
            "text": "The plot in three beats",
            "heading_tag": "h2",
            "text_color": "",
            "gradient": ""
          }
        },
        "richtext_story_beats": {
          "type": "richtext",
          "settings": {
            "content": "<p><strong>1. Mouse enters the wood.</strong> Fox, Owl and Snake each invite Mouse home for a meal, but Mouse knows he is really on the menu.</p><p><strong>2. Mouse invents the Gruffalo.</strong> He describes a fearsome creature with tusks, claws, orange eyes and purple prickles, frightening the predators away.</p><p><strong>3. The Gruffalo appears.</strong> When the creature turns out to be real, Mouse uses the same trick in reverse and proves he is the scariest creature in the wood.</p>"
          }
        }
      },
      "block_order": [
        "subheading_story_shape",
        "heading_story_beats",
        "richtext_story_beats"
      ],
