    "rich_text_themes": {
      "type": "rich-text",
      "blocks": {
        "subheading_why_it_works": {
          "type": "subheading",
          "settings": {
            "text": "Why children come back to it"
          }
        },
        "heading_why_it_works": {
          "type": "heading",
          "settings": {
            "text": "Why The Gruffalo works so well",
            "heading_tag": "h2",
            "text_color": "",
            "gradient": ""
          }
        },
        "richtext_why_it_works": {
          "type": "richtext",
          "settings": {
            "content": "<ul><li><strong>Repetition:</strong> children can anticipate the pattern of each encounter in the wood.</li><li><strong>Rhyme and rhythm:</strong> the language is memorable, musical and satisfying to hear aloud.</li><li><strong>Clear stakes:</strong> Mouse is small, the other animals are hungry, and every scene has a simple problem to solve.</li><li><strong>A clever twist:</strong> the made-up Gruffalo becomes real, turning the story into a playful test of Mouse's bravery.</li></ul>"
          }
        }
      },
      "block_order": [
        "subheading_why_it_works",
        "heading_why_it_works",
        "richtext_why_it_works"
      ],
